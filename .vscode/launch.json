{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (Windows MinGW)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/viewer.exe",
            "args": ["${workspaceFolder}/img_2.jpg"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/msys64/mingw64/bin;${env:PATH}"
                }
            ],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
            "preLaunchTask": "Build"
        },
        {
            "name": "Debug (Mac)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/viewer",
            "args": ["${workspaceFolder}/img_2.jpg"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "lldb",
            "preLaunchTask": "Build"
        }
    ]
}
